# =============================================================================
# Portfolio environment variables
# Copy this file to .env.local and fill in the blanks. Never commit real secrets.
# All external integrations are free-tier; no paid API keys required.
# =============================================================================

# ---- Core identifiers --------------------------------------------------------
GITHUB_USERNAME=bahakizil
MEDIUM_USERNAME=bahakizil
HUGGINGFACE_USERNAME=bahakizil

# ---- Optional credentials ----------------------------------------------------
# GitHub personal access token (optional; only lifts the 60 req/hour anonymous
# rate limit to 5000 req/hour). public_repo scope is enough.
GITHUB_API_TOKEN=

# Resend transactional email for the contact form (free tier: 3k/month)
# https://resend.com
RESEND_API_KEY=
RESEND_FROM="Portfolio <hi@yourdomain.com>"
RESEND_TO=kizilbaha26@gmail.com

# ---- Manual-refresh security token ------------------------------------------
# Required by POST /api/refresh-data (used for local dev only). Generate a
# strong random string; keep it out of the frontend bundle.
DATA_REFRESH_TOKEN=

# ---- Base URL ---------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://bahakizil.vercel.app
