# =============================================================================
# Portfolio environment variables
# Copy this file to .env.local and fill in the blanks. Never commit real secrets.
# =============================================================================

# ---- Core identifiers --------------------------------------------------------
GITHUB_USERNAME=bahakizil
MEDIUM_USER_ID=60a0e4269377

# ---- API credentials ---------------------------------------------------------
# GitHub personal access token (public_repo read scope is enough)
GITHUB_API_TOKEN=

# RapidAPI key for Medium2 + LinkedIn Data Scraper
RAPIDAPI_KEY=

# Resend (transactional email for the contact form)
RESEND_API_KEY=
RESEND_FROM="Portfolio <hi@yourdomain.com>"
RESEND_TO=kizilbaha26@gmail.com

# ---- Cron / refresh security -------------------------------------------------
# Strong random token used by /api/refresh-data and scripts/refresh-data.js
DATA_REFRESH_TOKEN=

# Vercel Cron shared secret (Vercel injects this header automatically)
CRON_SECRET=

# ---- Base URLs (optional) ----------------------------------------------------
# Used by server-side fetches during refresh-data; defaults to localhost for dev
NEXT_PUBLIC_SITE_URL=https://bahakizil.vercel.app
